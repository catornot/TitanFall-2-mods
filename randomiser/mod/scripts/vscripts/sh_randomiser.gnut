	]

	string function RandomiserGetRandomPilotOffhand(array<string> last_offhands) {
		array<string> offhands = clone pilotOffhands

		if (RandomiserNoLimitsEnabled()) {
			offhands.extend(titanOffhands)
			offhands.extend(titanDefenses)
			offhands.extend(titanTacticals)
		}

		foreach (offhand in last_offhands) {
			offhands.removebyvalue(offhand)
		}

		return offhands[RandomInt(offhands.len())]
	}

	string function RandomiserGetRandomTitanOffhand(array<string> bonus_offhands, array<string> last_offhands) {
		array<string> offhands = clone titanOffhands
		offhands.extend(bonus_offhands)

		if (RandomiserNoLimitsEnabled()) {
			offhands.extend(pilotOffhands)
		}

		foreach (offhand in last_offhands) {
			offhands.removebyvalue(offhand)
		}

		return offhands[RandomInt(offhands.len())]
	}

