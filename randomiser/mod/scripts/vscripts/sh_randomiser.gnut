	]

	string function RandomiserGetRandomTitanCore() {
		return titanCores[RandomInt(titanCores.len())]
	}

#if SERVER
	void function GivePlayerRandomiser(entity player) {
		if (RandomiserPilotsEnabled()) {
			int loadoutIndex = GetActivePilotLoadoutIndex(player)
			PilotLoadoutDef loadout = GetPilotLoadoutFromPersistentData(player, loadoutIndex)

			string burncardRef = GetSelectedBurnCardRef(player)
			BurnReward burnReward = BurnReward_GetByRef(burncardRef)

			array<string> offhandExclusions = []
			offhandExclusions.append(burnReward.weaponName)

			if (burncardRef == "burnmeter_random_foil") {
				foreach (burnReward in burn.allCards) {
					offhandExclusions.append(burnReward.weaponName)
				}
			}

			loadout.primary = RandomiserGetRandomPilotWeapon()
			loadout.primaryAttachments = []
			loadout.primaryMods = []

			loadout.secondary = RandomiserGetRandomPilotWeapon()
			loadout.secondaryMods = []

			loadout.weapon3 = RandomiserGetRandomPilotWeapon()
			loadout.weapon3Mods = []

			loadout.special = RandomiserGetRandomPilotOffhand(offhandExclusions)
			offhandExclusions.append(loadout.special)
			loadout.ordnance = RandomiserGetRandomPilotOffhand(offhandExclusions)

			loadout.melee = RandomiserGetRandomPilotMelee()
			loadout.meleeMods = []

			GivePilotLoadout(player, loadout)
		}
	}

	void function ApplyTitanRandomiser(entity player, TitanLoadoutDef loadout) {
		if (RandomiserTitansEnabled()) {
			array<string> chassis = RandomiserGetRandomTitanChassis()

			loadout.name = "???"

			loadout.titanClass = chassis[0]
			loadout.setFile = chassis[1]
			loadout.isPrime = chassis[2]
			loadout.titanExecution = chassis[3]

			array<string> offhandExclusions = []
			if (loadout.titanExecution == "execution_northstar_prime") {
				offhandExclusions.append("mp_titanweapon_salvo_rockets")
			}

			loadout.primary = RandomiserGetRandomTitanWeapon()
			loadout.primaryMod = ""
			loadout.primaryMods = []

			loadout.special = RandomiserGetRandomTitanOffhand(titanDefenses, offhandExclusions)
			loadout.specialMods = []
			offhandExclusions.append(loadout.special)

			loadout.antirodeo = RandomiserGetRandomTitanOffhand(titanTacticals, offhandExclusions)
			loadout.antirodeoMods = []
			offhandExclusions.append(loadout.antirodeo)

			loadout.ordnance = RandomiserGetRandomTitanOffhand([], offhandExclusions)
			loadout.ordnanceMods = []

			loadout.coreAbility = RandomiserGetRandomTitanCore()

			loadout.passive1 = "pas_enhanced_titan_ai"
			loadout.passive2 = "pas_hyper_core"
			loadout.passive3 = "pas_bubbleshield"
			loadout.passive4 = "pas_vanguard_core1"
			loadout.passive5 = "pas_vanguard_core5"
			loadout.passive6 = "pas_vanguard_core8"

			loadout.melee = RandomiserGetRandomTitanMelee()
		}
	}
#endif