	string function RandomiserGetRandomPilotWeapon() {
		array<string> weapons = clone pilotWeapons

		if (RandomiserNoLimitsEnabled()) {
			weapons.extend(titanWeapons)
		}

		return weapons[RandomInt(weapons.len())]
	}

	string function RandomiserGetRandomTitanWeapon() {
		array<string> weapons = clone titanWeapons

		// if (RandomiserNoLimitsPWFTEnabled()) {
		// 	weapons.extend(pilotWeapons)
		// }

		return weapons[RandomInt(weapons.len())]
	}

