	array<string> function RandomiserGetRandomTitanChassis() {
		array< array<string> > randomClassData = titanChassis[RandomInt(titanChassis.len())]

		string randomTitanClass = randomClassData[0][RandomInt(randomClassData[0].len())]

		int randomSetNumber = RandomInt(randomClassData[1].len())
		string randomSetFile = randomClassData[1][randomSetNumber]
		string primeStatus = randomSetNumber == 1 ? "titan_is_prime" : "titan_is_not_prime"

		string randomExecution = randomClassData[2][RandomInt(randomClassData[2].len())]

		return [randomTitanClass, randomSetFile, primeStatus, randomExecution]
	}

