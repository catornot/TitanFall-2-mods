global function Randomiser_Init

void function Randomiser_Init() {
	PrecacheModel( $"models/titans/buddy/titan_buddy.mdl" )
	PrecacheModel( $"models/weapons/arms/buddypov.mdl" )
	PrecacheParticleSystem( $"P_BT_eye_SM" )

	AddPrivateMatchModeSettingEnum("#MODE_SETTING_CATEGORY_RANDOMISER", "randomiser_pilots", ["#SETTING_DISABLED", "#SETTING_ENABLED"], "0")
	AddPrivateMatchModeSettingEnum("#MODE_SETTING_CATEGORY_RANDOMISER", "randomiser_titans", ["#SETTING_DISABLED", "#SETTING_ENABLED"], "0")
	AddPrivateMatchModeSettingEnum("#MODE_SETTING_CATEGORY_RANDOMISER", "randomiser_no_limits", ["#SETTING_DISABLED", "#SETTING_ENABLED"], "0")
	//AddPrivateMatchModeSettingEnum("#MODE_SETTING_CATEGORY_RANDOMISER", "randomiser_no_limits_pilots_weapons_for_titans", ["#SETTING_DISABLED", "#SETTING_ENABLED"], "0")

	#if SERVER
		AddCallback_OnPlayerRespawned(GivePlayerRandomiser)
		AddCallback_OnUpdateDerivedPlayerTitanLoadout(ApplyTitanRandomiser)
	#endif
}

// Enabled Functions
	bool function RandomiserPilotsEnabled() {
		return GetCurrentPlaylistVarInt("randomiser_pilots", 0) == 1
	}

	bool function RandomiserTitansEnabled() {
		return GetCurrentPlaylistVarInt("randomiser_titans", 0) == 1
	}

	bool function RandomiserNoLimitsEnabled() {
		return GetCurrentPlaylistVarInt("randomiser_no_limits", 0) == 1
	}

	// bool function RandomiserNoLimitsPWFTEnabled() {
	// 	return GetCurrentPlaylistVarInt("randomiser_no_limits_pilots_weapons_for_titans", 0) == 1
	// }

